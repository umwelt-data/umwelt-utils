{
  "name": "@umwelt-data/umwelt-utils",
  "version": "0.1.2",
  "description": "Shared utilities for the Olli and Umwelt projects.",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/umwelt-data/umwelt-utils.git"
  },
  "type": "module",
  "exports": {
    "./vl-bridge": {
      "types": "./dist/vl-bridge/index.d.ts",
      "import": "./dist/vl-bridge/index.js",
      "require": "./dist/vl-bridge/index.cjs"
    },
    "./bluefish-bridge": {
      "types": "./dist/bluefish-bridge/index.d.ts",
      "import": "./dist/bluefish-bridge/index.js",
      "require": "./dist/bluefish-bridge/index.cjs"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js",
      "require": "./dist/data/index.cjs"
    },
    "./vega": {
      "types": "./dist/vega/index.d.ts",
      "import": "./dist/vega/index.js",
      "require": "./dist/vega/index.cjs"
    },
    "./predicate": {
      "types": "./dist/predicate/index.d.ts",
      "import": "./dist/predicate/index.js",
      "require": "./dist/predicate/index.cjs"
    },
    "./description": {
      "types": "./dist/description/index.d.ts",
      "import": "./dist/description/index.js",
      "require": "./dist/description/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.1",
    "@types/d3-scale": "^4.0.8",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
